{
  "name": "arquitetura-node-typescript",
  "version": "1.0.0",
  "description": "API de exemplo em Node.js 24 (TypeScript nativo, sem tsc) com arquitetura modular por domínio, Express, MongoDB, Zod e Swagger/OpenAPI.",
  "type": "module",
  "main": "src/server.ts",
  "engines": {
    "node": "24.x"
  },
  "imports": {
    "#modules/*.ts": "./src/modules/*.ts",
    "#routes/*.ts": "./src/routes/*.ts",
    "#shared/*.ts": "./src/shared/*.ts"
  },
  "scripts": {
    "dev": "node --watch ./src/server.ts",
    "start": "node ./src/server.ts",
    "test": "node --test",
    "test:unit": "node --test \"test/unit/**/*.unit.test.ts\"",
    "test:integration": "node --test \"test/integration/**/*.integration.test.ts\"",
    "test:e2e": "node --test \"test/e2e/**/*.e2e.test.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@cspell/dict-pt-br": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongoose": "^9.7.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
